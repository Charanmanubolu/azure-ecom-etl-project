{
	"name": "DS_RAW_PARQUET",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_ADLS_RAW",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"EntityName": {
				"type": "string"
			},
			"YEAR": {
				"type": "string"
			},
			"MONTH": {
				"type": "string"
			},
			"DAY": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": "@concat(dataset().EntityName,'.parquet')",
				"folderPath": {
					"value": "@concat(dataset().EntityName,'/',dataset().YEAR,'/',dataset().MONTH,'/',dataset().DAY)",
					"type": "Expression"
				},
				"fileSystem": "raw"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}